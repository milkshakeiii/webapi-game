{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shattered-archive.local/schemas/puzzle.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "bench_capacity", "step_limit", "contract", "reagents"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "bench_capacity": {
      "type": "integer",
      "minimum": 2
    },
    "step_limit": {
      "type": "integer",
      "minimum": 1
    },
    "contract": {
      "$ref": "./contract.schema.json"
    },
    "reagents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./reagent.schema.json"
      }
    }
  }
}
