;name GridScout
; Grid-aware: scan all 4 directions, fork to empty ones
SCAN $8, #0       ; scan right
JMZ $2, $8        ; if empty, fork right
JMP $2, #0        ; skip
FORK #0, #9       ; fork right with payload
SCAN $8, #1       ; scan down
JMZ $2, $8        ; if empty, fork down
JMP $2, #0        ; skip
FORK #1, #9       ; fork down with payload
JMP $-8, #0       ; loop (only scans right/down for compactness)
DAT #0, #0        ; scratch for scan results
