;name GridSweep
;strategy: on grid/torus, cycle through all 4 edges with computed FORK + MOD
FORK $6, #7       ; fork to computed edge, copy 7 cells
ADD #1, $5        ; increment edge counter
MOD #4, $4        ; wrap mod 4 (grid has 4 edges)
ADD #2, $3        ; advance bomb pointer
MOV #0, @2        ; bomb
JMP $-5, #0       ; loop
DAT #0, #0        ; edge counter (cycles 0,1,2,3,0,1...)
DAT #0, #7        ; bomb pointer
