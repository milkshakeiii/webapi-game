;name Mirror
; Fork to spread, then scan for enemy code and bomb it
FORK #0, #7      ; spread to edge 0
FORK #1, #7      ; spread to edge 1
CMP $5, $6       ; compare two cells ahead
JMP $2, #0       ; if equal, skip bombing
MOV #0, $4       ; if different, bomb it
ADD #1, $3       ; advance scan pointer
JMP $-4, #0      ; loop
